# 1. Deny everything
/*

# 2. Allow Git config
!.gitignore

# 3. Global Ignores (Apply to all un-ignored folders)
# Security & OS junk
**/secrets.yaml
**/*.log
**/.DS_Store
**/__pycache__/

# 4. Whitelist: The .config directory
!.config/
.config/*

# --- App Whitelists ---

# Dev Tools
!.config/alacritty/
!.config/docker/
!.config/nvim/
!.config/tmux/        # Suggestion: If you use tmux
!.config/zsh/
!.config/oh-my-zsh/
!.config/rofi/
!.config/warp-terminal/

# System / Infra
!.config/infrastructure/
!.config/samba/

# --- Home Automation ---

# Frigate
!.config/frigate/
.config/frigate/storage/*
.config/frigate/cache/*
.config/frigate/faces/*
.config/frigate/model_cache/*
.config/frigate/*.db
.config/frigate/*.db-journal

# Home Assistant
!.config/home-assistant/*
.config/home-assistant/.storage/*
.config/home-assistant/*.db
.config/home-assistant/*.db-shm
.config/home-assistant/*.db-wal
.config/home-assistant/backups/ # Don't commit local HA backups
.config/home-assistant/tts/     # Don't commit generated text-to-speech audio